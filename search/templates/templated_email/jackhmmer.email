{% block subject %}[HMMER] Jackhmmer job {{ job.id }} FINISHED{% endblock %}
{% block html %}
    <p>Dear user,</p>

    <p>Your jackhmmer job <a href="{{ result_url }}">{{ job.id }}</a> submitted on {{ job.date_submitted|date:"r" }} has reached {% if reached_convergence %}convergence{% else %}desired number of iterations{% endif %}.</p>

    <p>Regards,<br>HMMER team</p>
{% endblock %}