{% block subject %}[HMMER] Job {{ job.id }} COMPLETED{% endblock %}
{% block html %}
    <p>Dear user,</p>

    <p>Your job <a href="{{ result_url }}">{{ job.id }}</a> submitted on {{ job.date_submitted|date:"r" }} has completed successfully.</p>

    <p>Regards,<br>HMMER team</p>
    <img src="{{ hmmer_logo }}">
{% endblock %}