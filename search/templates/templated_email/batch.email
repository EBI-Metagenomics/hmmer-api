{% block subject %}[HMMER] Batch {{ job.algo }} job {{ job.id }} COMPLETED{% endblock %}
{% block html %}
    <p>Dear user,</p>

    <p>Your {{ job.algo }} batch job <a href="{{ result_url }}">{{ job.id }}</a> submitted on {{ job.date_submitted|date:"r" }} has completed.</p>

    <p>Regards,<br>HMMER team</p>
{% endblock %}